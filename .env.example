# ============================================================
# 喵喵GPT源头 — 环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================================

# 【必填】管理员登录密码，请设置一个强密码
ADMIN_PASSWORD=Asd=235689030466

# 【推荐】管理后台访问路径（不含开头斜杠），不设置则每次重启随机生成
# 设置后访问地址为: http://your-domain.com/ADMIN_PATH
ADMIN_PATH=my-secret-admin-panel

# 【可选】服务端口，默认 3000
# PORT=3000

# 【可选】允许跨域的来源域名（前后端分离时填写，同服务器部署留空）
# ALLOWED_ORIGIN=https://yourdomain.com

# 【可选】代理白名单域名，逗号分隔（默认 chatgpt.com,chat.openai.com）
# PROXY_ALLOWED_HOSTS=chatgpt.com,chat.openai.com
